            "name": "services",
            "status": "confirmed"
        },
        {
            "name": "bookings",
            "status": "confirmed"
        }
    ],
    "entities": {
        "User": {
            "table": "users",
            "fields": {
                "id": "string",
                "email": "string",
                "phone": "string | null",
                "passwordHash": "string",
                "type": "string",
                "status": "string",
                "cityBase": "string | null",
                "lastLat": "number | null",
                "lastLng": "number | null",
                "createdAt": "string",
                "updatedAt": "string"
            },
            "known_examples": {
                "type": [
                    "ALUNO",
                    "PERSONAL"
                ],
                "status": [
                    "ATIVO"
                ]
            }
        },
        "Service": {
            "table": "services",
            "fields": {
                "id": "string",
                "providerId": "string",
                "durationMinutes": "number",
                "price": "number",
                "unitId": "string | null",
                "description": "string | null",
                "type": "ServiceType",
                "isActive": "boolean",
                "providerType": "ProviderType",
                "name": "string",
                "modality": "string",
                "currency": "string",
                "createdAt": "string",
                "updatedAt": "string"
            }
        },
        "ScheduleSlot": {
            "table": "schedule_slots",
            "fields": {
                "id": "string",
                "status": "ScheduleSlotStatus",
                "serviceId": "string",
                "startsAt": "string",
                "endsAt": "string",
                "studentId": "string | null",
                "createdAt": "string",
                "updatedAt": "string"
            }
        },
        "Booking": {
            "table": "bookings",
            "fields": {
                "id": "string",
                "serviceId": "string",
                "slotId": "string",
                "studentId": "string",
                "status": "BookingStatus",
                "cancelledAt": "string | null",
                "createdAt": "string",
                "updatedAt": "string"
            }
        }
    },
    "enums": {
        "ServiceType": [
            "DIARIA",
            "SESSAO",
            "PLANO_MENSAL",
            "DAY_PASS"
        ],
        "ProviderType": [
            "PERSONAL",
            "ACADEMIA"
        ],
        "ScheduleSlotStatus": [
            "AVAILABLE",
            "BOOKED",
            "BLOCKED"
        ],
        "BookingStatus": [
            "PENDING",
            "CONFIRMED",
            "CANCELLED"
        ]
    },
    "confirmed_api_endpoints": [
        {
            "key": "createBooking",
            "method": "POST",
            "path": "/bookings",
            "summary": "Creates a booking for a student in a specific service slot",
            "request": {
                "headers": {
                    "Content-Type": "application/json"
                },
                "body": {
                    "studentId": "string",
                    "serviceId": "string",
                    "slotId": "string"
                }
            },
            "success_response": {
                "statusCode": 200,
                "example": {
                    "id": "ad28eb2d-06b5-4232-8557-483076c300da",
                    "serviceId": "33333333-3333-3333-3333-333333333333",
                    "slotId": "44444444-4444-4444-4444-444444444444",
                    "studentId": "11111111-1111-1111-1111-111111111111",
                    "status": "CONFIRMED",
                    "cancelledAt": null,
                    "createdAt": "2026-04-20T03:27:17.532Z",
                    "updatedAt": "2026-04-20T03:27:17.532Z"
                }
            },
            "side_effects": [
                "The corresponding schedule slot becomes BOOKED."
            ]
        },
        {
            "key": "cancelBooking",
            "method": "PATCH",
            "path": "/bookings/:bookingId/cancel",
            "summary": "Cancels an existing booking",
            "request": {
                "headers": {
                    "Content-Type": "application/json"
                },
                "pathParams": {
                    "bookingId": "string"
                },
                "body": {
                    "studentId": "string"
                }
            },
            "success_response": {
                "statusCode": 200,
                "example": {
                    "id": "ad28eb2d-06b5-4232-8557-483076c300da",
                    "serviceId": "33333333-3333-3333-3333-333333333333",
                    "slotId": "44444444-4444-4444-4444-444444444444",
                    "studentId": "11111111-1111-1111-1111-111111111111",
                    "status": "CANCELLED",
                    "cancelledAt": "2026-04-20T03:36:53.265Z",
                    "slot": {
                        "id": "44444444-4444-4444-4444-444444444444",
                        "serviceId": "33333333-3333-3333-3333-333333333333"
                    }
                }
            },
            "side_effects": [
                "The schedule slot becomes AVAILABLE again.",
                "The schedule slot studentId becomes null."
            ]
        }
    ],
    "known_error_responses": [
        {
            "scenario": "slot_not_available",
            "endpoint": "POST /bookings",
            "statusCode": 400,
            "example": {
                "message": "Slot is not available (current status: BOOKED)",
                "error": "Bad Request",
                "statusCode": 400
            }
        },
        {
            "scenario": "booking_already_cancelled",
            "endpoint": "PATCH /bookings/:bookingId/cancel",
            "statusCode": 400,
            "example": {
                "message": "Booking is already cancelled",
                "error": "Bad Request",
                "statusCode": 400
            }
        }
    ],
