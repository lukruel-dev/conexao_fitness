{
    "meta": {
        "document_name": "backend_summary_v2",
        "purpose": "Frontend handoff document for AI-assisted UI generation",
        "project_name": "conexao-fitness",
        "api_style": "REST JSON",
        "notes": [
            "This document mixes confirmed backend behavior with clearly labeled inferred frontend needs.",
            "Confirmed behaviors were manually validated for bookings create/cancel flow."
        ]
    },
    "backend_stack": {
