    ],
    "core_business_rules": [
        {
            "id": "BR-001",
            "rule": "A booking can only be created for a schedule slot with status AVAILABLE."
        },
        {
            "id": "BR-002",
            "rule": "When a booking is created successfully, its status is CONFIRMED."
        },
        {
            "id": "BR-003",
            "rule": "When a booking is created, the linked schedule slot changes to BOOKED."
        },
        {
            "id": "BR-004",
            "rule": "A BOOKED slot cannot be booked again."
        },
        {
            "id": "BR-005",
            "rule": "When a booking is cancelled, booking.status becomes CANCELLED and cancelledAt is filled."
        },
        {
            "id": "BR-006",
            "rule": "When a booking is cancelled, the linked schedule slot returns to AVAILABLE."
        },
        {
            "id": "BR-007",
            "rule": "When a booking is cancelled, the slot studentId becomes null."
        },
        {
            "id": "BR-008",
            "rule": "A booking that is already cancelled cannot be cancelled again."
        }
    ],
